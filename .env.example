APP_NAME=SenFlote
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=senflote
DB_USERNAME=senflote
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Queue & Broadcasting
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=redis
CACHE_STORE=redis

# Traccar
TRACCAR_WEBHOOK_SECRET=traccar-shared-secret
TRACCAR_API_URL=http://traccar:8082/api
TRACCAR_API_USER=admin
TRACCAR_API_PASSWORD=admin

# Pusher/Soketi (for WebSocket broadcasting)
PUSHER_APP_ID=senflote
PUSHER_APP_KEY=senflote_key
PUSHER_APP_SECRET=senflote_secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@senflote.sn
MAIL_FROM_NAME="${APP_NAME}"
